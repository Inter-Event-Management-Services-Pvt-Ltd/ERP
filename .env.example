# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_REQUEST_TIMEOUT_SECONDS=5
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# API
API_BASE_URL=http://localhost:8000
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_EMAIL_DOMAIN=iemsnewdelhi.com
# Optional comma-separated override for local/staging. If set, this replaces
# ALLOWED_EMAIL_DOMAIN. Keep production scoped to approved IEMS domains only.
ALLOWED_EMAIL_DOMAINS=
CORS_ALLOWED_ORIGINS=http://localhost:3000
DIRECTOR_EMAIL=director@iemsnewdelhi.com

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Signed URLs and archive exports
SIGNED_URL_TTL_SECONDS=900
ARCHIVE_EXPORT_TTL_HOURS=24
MAX_UPLOAD_BYTES=104857600
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
PROJECT_DOCUMENTS_BUCKET=project-documents
GENERATED_ARCHIVES_BUCKET=generated-archives

# Frontend
# Local dev: http://localhost:8000  |  Docker behind Caddy: /api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# Reverse proxy
IEMS_DOMAIN=localhost
